{
  "name": "commently",
  "displayName": "Commently — AI Comment Generator for LinkedIn",
  "version": "1.0.0",
  "description": "Free AI-powered LinkedIn comment generator. Supports OpenAI API and local LLMs (Ollama). Open source by AgentCoreX.",
  "author": "AgentCoreX",
  "homepage": "https://agent-corex.com",
  "repository": "https://github.com/ankitpro/commently",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "plasmo": "latest",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "host_permissions": [
      "https://www.linkedin.com/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://api.openai.com/*"
    ],
    "permissions": [
      "storage",
      "tabs",
      "scripting"
    ]
  }
}
